<TechnologyStack VERSION="1.2.0">
  <!-- Runtime and language -->
  <Runtime>Browser Extension - Chrome/Firefox</Runtime>
  <Language>TypeScript 5.3.3</Language>

  <!-- Framework -->
  <Framework>Vue 3.5.27</Framework>

  <!-- Build tool -->
  <BuildTool>WXT 0.20.14 - Web Extension Framework</BuildTool>

  <!-- Key libraries and dependencies -->
  <Dependencies>
    <!-- Core PDF libraries -->
    <dep-pdfjs name="pdfjs-dist" version="5.4.449" purpose="PDF rendering and page extraction for compression" />
    <dep-pdf-lib name="pdf-lib" version="1.17.1" purpose="PDF creation and manipulation for output file" />
    
    <!-- Vue ecosystem -->
    <dep-vueuse name="@vueuse/core" version="14.2.0" purpose="Vue composition utilities" />
    <dep-radix name="radix-vue" version="1.9.17" purpose="Headless UI components" />
    <dep-reka name="reka-ui" version="2.8.0" purpose="UI component primitives" />
    
    <!-- Styling -->
    <dep-tailwind name="tailwindcss" version="3.4.19" purpose="Utility-first CSS framework" />
    <dep-tailwind-animate name="tailwindcss-animate" version="1.0.7" purpose="Animation utilities for Tailwind" />
    <dep-cva name="class-variance-authority" version="0.7.1" purpose="Component variant management" />
    <dep-clsx name="clsx" version="2.1.1" purpose="Conditional class names" />
    <dep-tailwind-merge name="tailwind-merge" version="3.4.0" purpose="Merge Tailwind classes without conflicts" />
    
    <!-- Testing -->
    <dep-vitest name="vitest" version="1.1.0" purpose="Unit testing framework" />
    <dep-fast-check name="fast-check" version="3.15.0" purpose="Property-based testing" />
    <dep-jsdom name="jsdom" version="27.2.0" purpose="DOM simulation for tests" />
  </Dependencies>

  <!-- Version constraints -->
  <VersionConstraints>
    <constraint-pdfjs lib="pdfjs-dist" min="5.0.0" max="5.x" reason="Using latest PDF.js API for rendering" />
    <constraint-pdf-lib lib="pdf-lib" min="1.17.0" max="1.x" reason="Stable PDF creation API" />
    <constraint-vue lib="vue" min="3.5.0" max="3.x" reason="Using Vue 3 composition API features" />
    <constraint-wxt lib="wxt" min="0.20.0" max="0.x" reason="Manifest V3 support and side panel API" />
    <constraint-typescript lib="typescript" min="5.0.0" max="5.x" reason="Using modern TypeScript features" />
  </VersionConstraints>

  <!-- Build and tooling -->
  <Tooling>
    <tool-bundler name="bundler" value="Vite" version="5.0.8" />
    <tool-test-runner name="test-runner" value="Vitest" version="1.1.0" />
    <tool-linter name="type-check" value="TypeScript" version="5.3.3" />
    <tool-css name="css-processor" value="PostCSS" version="8.5.6" />
  </Tooling>

  <!-- Extension manifest -->
  <Extension>
    <manifest-version value="3" />
    <permissions>
      <permission>sidePanel</permission>
    </permissions>
    <entry-points>
      <entry-sidepanel path="entrypoints/sidepanel/" />
      <entry-background path="entrypoints/background.ts" />
    </entry-points>
  </Extension>

</TechnologyStack>
